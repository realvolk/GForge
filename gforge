#!/usr/bin/env bash
set -Eeuo pipefail

VFF_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/VFF"
GFORGE_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

export VFF_DIR GFORGE_DIR

source "${VFF_DIR}/lib/core.sh"
source "${VFF_DIR}/lib/state.sh"

source "${VFF_DIR}/tui/forgetui.sh"
source "${VFF_DIR}/tui/selections.sh"

source "${VFF_DIR}/lib/fs/partition.sh"
source "${VFF_DIR}/lib/fs/filesystem.sh"
source "${VFF_DIR}/lib/fs/mount.sh"
source "${VFF_DIR}/lib/boot/grub.sh"
source "${VFF_DIR}/lib/boot/uki.sh"
source "${VFF_DIR}/lib/boot/efistub.sh"
source "${VFF_DIR}/lib/boot/refind.sh"
source "${VFF_DIR}/lib/init/services.sh"
source "${VFF_DIR}/lib/net/network.sh"
source "${VFF_DIR}/lib/hw/cpu.sh"
source "${VFF_DIR}/lib/hw/gpu.sh"
source "${VFF_DIR}/lib/system/hostname.sh"
source "${VFF_DIR}/lib/users.sh"
source "${VFF_DIR}/lib/post/install.sh"
source "${VFF_DIR}/lib/stage/pipeline.sh"

source "${GFORGE_DIR}/profiles/gentoo.sh"
source "${GFORGE_DIR}/lib/tui/gentoo.sh"
source "${GFORGE_DIR}/lib/helpers/cpu-optimize.sh"
source "${GFORGE_DIR}/lib/helpers/wiki.sh"
source "${GFORGE_DIR}/lib/helpers/fetch-handbook.sh"
source "${GFORGE_DIR}/lib/post/gentoo.sh"

vff_preflight() {
    require_root
    detect_boot_mode
    require_internet
    command -v jq >/dev/null || emerge --ask=n --oneshot app-misc/jq
    _require_tools ${VFF_REQUIRED_TOOLS:-}
    log_info "Preflight checks passed (boot mode: ${VFF_BOOT_MODE})"
}

gforge_welcome_art() {
    tui_msg_quick "GentooForge" "
   __________________
 < Gentoo Linux - live free >
  ------------------
         \\   ^__^
          \\  (oo)\\_______
             (__)\\       )\\/\\
                 ||----w |
                 ||     ||
"
}

gforge_welcome_art
vff_preflight
pkg_repo_setup
gforge_collect_config

partition_disk
create_filesystems
mount_filesystems
pkg_bootstrap
pkg_install "${BASE_PACKAGES[@]}"
configure_system
configure_users
gentoo_setup_network
run_post_install
configure_grub
gentoo_post_install

gforge_post_install_extras
gforge_save_profile
gforge_download_handbook
gforge_show_log
log_info "Gentoo installation complete. Reboot."